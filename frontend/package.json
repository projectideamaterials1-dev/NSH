{
  "name": "orbital-insight-crimson-nebula",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port=3000 --host=0.0.0.0",
    "clean": "rm -rf dist node_modules/.vite",
    "lint": "tsc --noEmit",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/extensions": "^9.2.11",
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "@luma.gl/core": "~9.2.6",
    "@luma.gl/engine": "~9.2.6",
    "@luma.gl/webgl": "~9.2.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "deck.gl": "^9.2.11",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^5.21.1",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/wicg-file-system-access": "^2023.10.5",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "@deck.gl/*": "^9.2.11",
    "@luma.gl/*": "~9.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}